.card {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--border);
  border-radius: 16px;
  background:
    radial-gradient(circle at top right, rgba(209, 163, 63, .055), transparent 34%),
    linear-gradient(160deg, rgba(21, 25, 34, .98), rgba(13, 16, 22, .98));
  box-shadow: 0 18px 48px rgba(0, 0, 0, .16);
}

.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 16px;
  border-bottom: 1px solid var(--border);
}

.headingGroup {
  min-width: 0;
}

.titleRow,
.headerActions,
.primaryToolbar,
.secondaryToolbar,
.secondaryToolbar > div,
.compareHeader,
.versionHeader,
.versionHeader > div:last-child,
.versionMeta {
  display: flex;
  align-items: center;
  gap: 8px;
}

.titleRow {
  flex-wrap: wrap;
}

.header h3 {
  margin: 0;
  font-size: 17px;
  line-height: 1.1;
}

.header p {
  margin: 7px 0 0;
  color: var(--muted);
  font-size: 9px;
  line-height: 1.5;
}

.score,
.versionCount {
  padding: 4px 7px;
  border-radius: 999px;
  font-size: 8px;
  font-weight: 800;
}

.score {
  border: 1px solid rgba(209, 163, 63, .28);
  background: rgba(209, 163, 63, .07);
  color: var(--gold-light);
}

.versionCount {
  background: rgba(124, 167, 255, .1);
  color: #abc1ee;
}

.headerActions {
  flex: 0 0 auto;
}

.headerActions button,
.primaryToolbar button,
.secondaryToolbar button,
.compareHeader button,
.versionHeader button,
.versionList article > button {
  min-height: 32px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: rgba(7, 9, 13, .48);
  color: var(--text);
  font-size: 8px;
  font-weight: 780;
}

.headerActions button:hover,
.primaryToolbar button:hover,
.secondaryToolbar button:hover,
.versionHeader button:hover,
.versionList article > button:hover {
  border-color: rgba(209, 163, 63, .35);
}

.primaryToolbar {
  flex-wrap: wrap;
  padding: 11px 14px;
  border-bottom: 1px solid var(--border);
  background: rgba(7, 9, 13, .2);
}

.primaryToolbar .copyButton {
  color: var(--gold-light);
}

.primaryToolbar .featuredAction {
  border-color: rgba(209, 163, 63, .32);
  background: rgba(209, 163, 63, .09);
  color: var(--gold-light);
}

.primaryToolbar button:disabled,
.secondaryToolbar button:disabled {
  cursor: wait;
  opacity: .52;
}

.contentBody {
  min-height: 120px;
  padding: 17px 16px 14px;
}

.contentBody p,
.candidateContent {
  margin: 0;
  color: var(--text);
  white-space: pre-wrap;
  overflow-wrap: anywhere;
  font-size: 11px;
  line-height: 1.78;
}

.secondaryToolbar {
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  padding: 10px 14px;
  border-top: 1px solid var(--border);
  background: rgba(7, 9, 13, .18);
}

.secondaryToolbar > span {
  color: var(--muted);
  font-size: 8px;
  font-weight: 750;
  letter-spacing: .06em;
  text-transform: uppercase;
}

.secondaryToolbar > div {
  flex-wrap: wrap;
}

.compare {
  margin: 12px 14px 14px;
  overflow: hidden;
  border: 1px solid rgba(209, 163, 63, .3);
  border-radius: 12px;
  background: rgba(209, 163, 63, .045);
}

.compareHeader {
  justify-content: space-between;
  padding: 11px 12px;
  border-bottom: 1px solid var(--border);
}

.compareHeader > div:first-child,
.versionHeader > div:first-child {
  display: grid;
  gap: 3px;
}

.compareHeader span,
.versionHeader span {
  color: var(--gold-light);
  font-size: 8px;
  font-weight: 800;
  letter-spacing: .06em;
  text-transform: uppercase;
}

.compareHeader strong,
.versionHeader strong {
  font-size: 10px;
}

.compareHeader > div:last-child {
  display: flex;
  gap: 7px;
}

.compareHeader button:first-child {
  border: 0;
  background: linear-gradient(140deg, var(--gold-light), var(--gold));
  color: #171106;
}

.candidateContent {
  padding: 14px;
}

.drawerBackdrop {
  position: fixed;
  z-index: 1000;
  inset: 0;
  display: flex;
  justify-content: flex-end;
  background: rgba(2, 4, 8, .72);
  backdrop-filter: blur(4px);
}

.versionDrawer {
  width: min(480px, 92vw);
  height: 100%;
  overflow-y: auto;
  border-left: 1px solid rgba(209, 163, 63, .24);
  background:
    radial-gradient(circle at top right, rgba(209, 163, 63, .08), transparent 28%),
    #0d1016;
  box-shadow: -24px 0 70px rgba(0, 0, 0, .38);
}

.versionHeader {
  position: sticky;
  z-index: 2;
  top: 0;
  justify-content: space-between;
  padding: 17px;
  border-bottom: 1px solid var(--border);
  background: rgba(13, 16, 22, .96);
  backdrop-filter: blur(12px);
}

.versionList {
  display: grid;
  gap: 10px;
  padding: 14px;
}

.versionList article {
  display: grid;
  gap: 11px;
  padding: 13px;
  border: 1px solid var(--border);
  border-radius: 11px;
  background: rgba(7, 9, 13, .48);
}

.versionMeta {
  flex-wrap: wrap;
}

.versionMeta strong {
  color: var(--gold-light);
}

.versionMeta span {
  padding: 4px 6px;
  border-radius: 999px;
  background: rgba(124, 167, 255, .1);
  color: #abc1ee;
  font-size: 8px;
}

.versionMeta small {
  color: var(--muted);
  font-size: 8px;
}

.versionList article p {
  margin: 0;
  color: var(--muted);
  white-space: pre-wrap;
  font-size: 9px;
  line-height: 1.6;
}

.versionList article > button {
  justify-self: start;
}

.emptyVersion {
  margin: 0;
  padding: 18px;
  color: var(--muted);
  font-size: 9px;
}

@media (max-width: 720px) {
  .header,
  .compareHeader,
  .versionHeader {
    align-items: stretch;
    flex-direction: column;
  }

  .headerActions,
  .versionHeader > div:last-child {
    align-self: flex-start;
  }

  .secondaryToolbar {
    align-items: flex-start;
    flex-direction: column;
  }
}
